<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:theme="@style/Theme.TestSchool"
    android:id="@+id/m_Prof_CardView"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    app:cardCornerRadius="20dp"
    app:cardElevation="10dp"
    android:layout_margin="10dp">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true">

        <ImageView
            android:id="@+id/prof_img"
            android:layout_width="82dp"
            android:layout_height="82dp"
            android:src="@color/white" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView
                android:layout_marginLeft="@dimen/total_font_size"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/profName"
                android:gravity="center"
                android:text="TeacherName"
                android:textSize="@dimen/total_font_size"
                android:textStyle="bold"/>
            <TextView
                android:layout_marginLeft="@dimen/total_font_size"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/prof_email"
                android:gravity="center"
                android:text="@string/prompt_email"
                android:textSize="@dimen/total_font_size"
                android:textStyle="bold"/>
            <TextView
                android:layout_marginLeft="@dimen/total_font_size"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:id="@+id/prof_phone"
                android:gravity="center"
                android:text="phone number"
                android:textSize="@dimen/total_font_size"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
