<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/intro"
    android:layout_width="fill_parent"
    android:layout_height="fill_parent"
    android:background="@color/school_color"
    app:layout_anchorGravity="center|center_horizontal|center_vertical"
    tools:context=".Activities.ProfileUserActivity">

    <View
        android:id="@+id/rectangle1"
        android:layout_width="141dp"
        android:layout_height="213dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginLeft="272dp"
        android:layout_marginTop="-36dp"
        android:layout_marginEnd="-2dp"
        android:background="@drawable/rectangle"
        android:rotation="90" />

    <TextView
        android:id="@+id/User"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="46dp"
        android:gravity="center"
        android:text="@string/user"
        android:textAppearance="@style/dashboard" />

    <TextView
        android:id="@+id/User_id"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="5dp"
        android:layout_centerHorizontal="true"
        android:layout_below="@+id/User"
        android:text="@string/id_number"
        android:textAppearance="@style/total_value" />

    <com.google.android.material.imageview.ShapeableImageView
        android:id="@+id/avatar"
        android:layout_width="113dp"
        android:layout_height="116dp"
        android:layout_below="@+id/User_id"
        android:layout_centerHorizontal="true"
        android:layout_marginLeft="146dp"
        android:layout_marginTop="5dp"
        android:src="@color/white"
        app:shapeAppearanceOverlay="@style/dashboardavatar" />

    <TextView
        android:id="@+id/userName"
        android:layout_width="197dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/avatar"
        android:layout_centerHorizontal="true"
        android:gravity="center_horizontal|center_vertical"
        android:text="@string/username"
        android:textSize="20sp"
        android:textColor="@color/white"/>
    <TextView
        android:id="@+id/email"
        android:layout_width="197dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/userName"
        android:layout_centerHorizontal="true"
        android:gravity="center_horizontal|center_vertical"
        android:text="@string/prompt_email"
        android:textSize="20sp"
        android:textColor="@color/white"/>
    <TextView
        android:id="@+id/phone"
        android:layout_width="197dp"
        android:layout_height="wrap_content"
        android:layout_below="@+id/email"
        android:layout_centerHorizontal="true"
        android:gravity="center_horizontal|center_vertical"
        android:text="@string/phone"
        android:textSize="20sp"
        android:textColor="@color/white"/>

    <RelativeLayout
        android:id="@+id/rectangle3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentStart="true"
        android:layout_alignParentLeft="true"
        android:layout_alignParentTop="true"
        android:layout_alignParentBottom="true"
        android:layout_marginTop="290dp"
        android:background="@drawable/rectangle3">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingLeft="20dp"
            android:paddingTop="50dp">

            <TextView
                android:id="@+id/classes"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:drawableRight="@drawable/blackarrow"
                android:drawableBottom="@drawable/line__"
                android:gravity="center_vertical"
                android:text="@string/setting"
                android:textColor="@color/school_color"
                android:textSize="25sp" />

            <TextView
                android:id="@+id/finance"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="15dp"
                android:layout_weight="1"
                android:drawableRight="@drawable/blackarrow"
                android:drawableBottom="@drawable/line__"
                android:gravity="center_vertical"
                android:text="@string/permissions"
                android:textColor="@color/school_color"
                android:textSize="25sp" />

        </LinearLayout>

    </RelativeLayout>

    <View
        android:id="@+id/rectangle"
        android:layout_width="304.75dp"
        android:layout_height="303.88dp"
        android:layout_alignParentStart="true"
        android:layout_marginTop="72.44dp"
        android:background="@drawable/rectangle" />


</RelativeLayout>
